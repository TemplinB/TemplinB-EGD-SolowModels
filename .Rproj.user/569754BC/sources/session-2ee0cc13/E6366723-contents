# ================ Sierra Leone

sierra_leone <- pwt_solow %>%
  filter(country == "Sierra Leone")

a <- sierra_leone$a[1]
s <- sierra_leone$s[1]
n <- sierra_leone$n[1]
d <- sierra_leone$d[1]
A <- sierra_leone$A[1]

# Continuous Curve
solow_df <- data.frame(
  k = seq(0, sierra_leone$k[1] * 2, length.out = 500)) %>%
  mutate(y = A * k^a,
         sfk = s * y,
         break_even = (n + d) * k)

# Steady State
k_star <- ((s * A) / (n + d))^(1 / (1 - a))
y_star <- A * k_star^a
sfk_star <- s * y_star

# Graph with Current Values

last_point <- solow_df %>%
  slice_tail(n = 1)


ggplot(solow_df, aes(x = k)) +
  geom_line(aes(y = y), linewidth = 1, color = "black") +
  geom_line(aes(y = sfk), linewidth = 1.2, color = "darkgreen") +
  geom_line(aes(y = break_even), linewidth = 1.2, color = "red") +
  
  geom_vline(xintercept = k_star, linetype = "dotted") +
  geom_point(aes(x = k_star, y = sfk_star), size = 2) +
  
  # ✅ Labels at end of lines
  annotate("text", 
           x = last_point$k, 
           y = last_point$y, 
           label = "y = f(k)", 
           hjust = -0.1) +
  
  annotate("text", 
           x = last_point$k, 
           y = last_point$sfk, 
           label = "s f(k)", 
           color = "darkgreen",
           hjust = -0.1) +
  
  annotate("text", 
