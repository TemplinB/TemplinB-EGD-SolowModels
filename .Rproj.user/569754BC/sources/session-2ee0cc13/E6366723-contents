                        "Senegal", "Cameroon", "Togo", 
                        "Sierra Leone", "Liberia", "United States")) %>% 
  filter(year >= 2022)

# median for labor share of income
pwt_base <- pwt_base %>%
  mutate(labsh = ifelse(country == "Ghana", median(labsh, na.rm = TRUE), labsh),
         labsh = ifelse(country == "Liberia", median(labsh, na.rm = TRUE), labsh))

pwt_base <- pwt_base %>% 
  mutate(y = rgdpo / emp,
         k = rnna / emp,
         n = ((emp / lag(emp)) -1),
         d = 0.05,
         a = (1 - labsh),
         L = emp,
         K = rnna,
         Y = rgdpo,
         A = Y / (K^a * L^(1 - a)))

pwt_solow <- pwt_base %>% 
  filter(year == 2023) %>% 
  select(country, Y, A, K, L, y, k, a, n, d)

pwt_solow <- pwt_solow %>%
  left_join(
    savings_rate_as_pct_gdp %>% select(country_name, s),
    by = c("country" = "country_name"))

