         x2023 = ifelse(country_name == "Liberia", median(x2023, na.rm = TRUE), x2023),
         country_name = ifelse(country_name == "Cote d'Ivoire", "Côte d'Ivoire", country_name),
         x2023 = x2023 / 100) %>% 
  rename(s = x2023)

